# .env.example — copy this to .env and fill in real values.
# NEVER commit .env with real secrets.

# PostgreSQL connection string (Neon serverless Postgres)
DATABASE_URL=postgres://user:password@host.neon.tech/dbname?sslmode=require

# Port the HTTP server listens on (default: 3000)
APP_PORT=3000

# Environment: development | production
# development → human-readable Zap logs + cookie Secure=false
# production  → JSON-structured Zap logs + cookie Secure=true
APP_ENV=development

# JWT signing secret — must be at least 32 characters.
# Generate a strong secret: openssl rand -hex 32
JWT_SECRET=your-super-secret-key-min-32-chars-here

# JWT token TTL in hours (default: 24)
JWT_EXPIRY_HOURS=24
